# Copy this file to a new file named ".env" and fill in your webhook.
# The bot loads .env automatically — no need to export anything.

# REQUIRED for alerts to actually send. Create an incoming webhook at
# https://api.slack.com/messaging/webhooks and paste the URL after the = sign.
# It looks like: hooks.slack.com/services/<team-id>/<bot-id>/<token>
POLYSIGNAL_SLACK_WEBHOOK_URL=

# Optional overrides (defaults shown):
POLYSIGNAL_TIME_PERIOD=WEEK
POLYSIGNAL_ORDER_BY=PNL
POLYSIGNAL_CATEGORY=OVERALL
POLYSIGNAL_TOP_N=5
POLYSIGNAL_NOTABLE_USD=5000
POLYSIGNAL_MIN_POSITION_USD=100
POLYSIGNAL_POLL_INTERVAL_SECONDS=900
POLYSIGNAL_SILENT_FIRST_RUN=true
POLYSIGNAL_DB_PATH=polysignal.db

# Quality filter (only alert on proven traders):
POLYSIGNAL_MIN_WIN_RATE=0.50
POLYSIGNAL_MIN_TRACK_RECORD_SAMPLE=10

# Health alerts:
POLYSIGNAL_FAILURE_ALERT_THRESHOLD=3
POLYSIGNAL_STALENESS_ALERT_HOURS=2
